# ──────────────────────────────────────────────────────────────────────────
# Photography Platform — environment template
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# Both the `web` and `worker` processes read this same env.
# ──────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
# Host port the `web` container is published on (container always listens on 3000)
WEB_PORT=3000
# Cloudflare Tunnel token (only when using the `tunnel` profile in compose.prod.yaml).
# Treat as a CRITICAL secret. Leave empty if NPM + cloudflared run outside compose.
TUNNEL_TOKEN=
# Public origin the app is served from (used for absolute URLs, auth, OG tags)
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL 16) ───────────────────────────────────────────────
# In compose the host is the `db` service; locally use 127.0.0.1
DATABASE_URL=postgres://photog:photog@db:5432/photography
# Values used by the `db` container itself:
POSTGRES_USER=photog
POSTGRES_PASSWORD=photog
POSTGRES_DB=photography

# ── Redis / Valkey (sessions, rate limit, BullMQ) ──────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth (Better Auth) — wired in Phase 2 ──────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# ── Media storage (StorageProvider) ────────────────────────────────────────
# Driver `minio` = any S3-compatible store. The stack ships SeaweedFS
# (Apache-2.0, S3 gateway on :8333). Alternate driver: `filesystem`.
STORAGE_DRIVER=minio
# S3 driver settings — point at the SeaweedFS S3 gateway.
S3_ENDPOINT=http://seaweedfs:8333
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=photography-media
S3_FORCE_PATH_STYLE=true
# NOTE: the S3 access key/secret above MUST match docker/seaweedfs/s3.json
# (SeaweedFS reads its identities from that file). Change both for production.
# Filesystem driver settings (only used when STORAGE_DRIVER=filesystem)
STORAGE_FS_PATH=/data/media

# ── Email (EmailProvider) ──────────────────────────────────────────────────
# Driver: `log` (default — logs only, sends nothing), `smtp`, or `resend`.
# A configured driver missing its credentials falls back to `log`.
EMAIL_DRIVER=log
EMAIL_FROM="Studio <hello@example.com>"
# Where new (non-spam) contact inquiries are emailed (defaults to EMAIL_FROM).
CONTACT_NOTIFY_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RESEND_API_KEY=

# ── Payments (PaymentProvider) — DEFERRED, stub only ───────────────────────
PAYMENTS_DRIVER=stub
STRIPE_SECRET_KEY=

# ── Instagram (optional) ───────────────────────────────────────────────────
# When set, the home "From the field" section pulls the real Instagram feed via
# the Graph API (InstagramProvider → Graph driver). Leave empty to fall back to
# recent public photos. Long-lived token; refresh per docs/AI-INTEGRATIONS.md.
IG_ACCESS_TOKEN=

# ── Slideshow video (Remotion) — opt-in; changes the deployment shape ───────
# Renders an MP4 slideshow from a gallery's photos. Requires the worker image to
# be built with --build-arg INSTALL_REMOTION_DEPS=true (bakes headless Chromium).
# See docs/AI-INTEGRATIONS.md. The admin endpoint returns 501 when disabled.
VIDEO_RENDER_ENABLED=false
INSTALL_REMOTION_DEPS=false

# ── Worker ─────────────────────────────────────────────────────────────────
# Port the worker exposes a tiny HTTP health endpoint on (container-internal)
WORKER_HEALTH_PORT=9091
# The worker applies DB migrations on boot. Set false to run them out-of-band.
RUN_MIGRATIONS=true

# ── Seed (npm run db:seed) ─────────────────────────────────────────────────
SEED_OWNER_EMAIL=owner@studio.local
SEED_OWNER_PASSWORD=change-me-now-please-12
